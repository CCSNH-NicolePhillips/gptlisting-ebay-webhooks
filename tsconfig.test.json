{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "jest"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": false
  },
  "include": [
    "src/**/*.ts",
    "netlify/functions/**/*.ts",
    "tests/**/*.ts",
    "apps/api/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "packages/core/src/**/*.ts",
    "packages/shared/src/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
