{
  "name": "gptlisting-ebay-webhooks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch apps/api/src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/index.js",
    "lint": "eslint --cache --max-warnings=0 --ext .ts,.tsx,.js src tests apps packages",
    "lint:fix": "eslint --cache --fix --ext .ts,.tsx,.js src tests apps packages",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "npm run lint && jest",
    "test:watch": "jest --watch",
    "test:coverage": "npm run lint && jest --coverage",
    "test:verbose": "npm run lint && jest --verbose",
    "smoke:sh": "bash scripts/smoke.sh",
    "smoke:ps": "pwsh -File scripts/smoke.ps1",
    "verify:golden": "tsx scripts/verify-golden.ts",
    "metrics:print": "tsx scripts/metrics-print.ts",
    "prepare": "husky install",
    "dev:api": "tsx watch apps/api/src/index.ts",
    "start:api": "node dist/apps/api/src/index.js",
    "lint:boundaries": "eslint --cache --max-warnings=0 --ext .ts,.tsx,.js packages apps",
    "check:no-netlify": "tsx scripts/check-no-netlify-imports.ts",
    "check:inventory": "tsx scripts/check-inventory.ts",
    "check:structure": "tsx scripts/check-structure.ts",
    "check:no-netlify:ps1": "powershell -File scripts/check-no-netlify-imports.ps1",
    "check:inventory:ps1": "powershell -File scripts/check-inventory.ps1",
    "check:structure:ps1": "powershell -File scripts/check-structure.ps1",
    "list-functions": "npx tsx scripts/list-netlify-functions.ts",
    "list-functions:diff": "npx tsx scripts/list-netlify-functions.ts --diff",
    "deploy": "railway up",
    "test:pricing-benchmark": "tsx scripts/test-pricing-benchmark.ts",
    "test:pricing-benchmark:verbose": "tsx scripts/test-pricing-benchmark.ts --verbose"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.21.1",
    "@aws-sdk/client-s3": "^3.931.0",
    "@aws-sdk/s3-request-presigner": "^3.931.0",
    "@google/generative-ai": "^0.7.1",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jose": "5.9.3",
    "ml-distance": "^4.0.0",
    "multer": "^2.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.59.0",
    "redis": "^5.9.0",
    "sharp": "^0.33.5",
    "undici": "^6.19.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.3",
    "esbuild": "^0.23.0",
    "eslint": "^9.11.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.50.0"
  }
}
