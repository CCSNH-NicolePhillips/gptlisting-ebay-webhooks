{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@core/*": ["packages/core/src/*"],
      "@shared/*": ["packages/shared/src/*"],
      "@api/*": ["apps/api/src/*"]
    }
  }
}
